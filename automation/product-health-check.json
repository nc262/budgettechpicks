            {
              "name": "message",
              "value": "=chore: nightly ASIN health \u2014 {{ $json.liveCount }}/{{ $json.total }} live, {{ $json.deadCount }} dead [automated]"
            },
            {
              "name": "content",
              "value": "={{ $json.base64Content }}"
