            "index": 0
          }
        ]
      ]
    },
    "Get Current Health SHA": {
      "main": [
        [
          {
            "node": "Build Health JSON",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
