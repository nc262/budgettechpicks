    {
      "id": "03-get-products",
      "name": "Get products.ts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/nc262/budgettechpicks/contents/src/data/products.ts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi"
      },
      "credentials": {
        "githubApi": {
          "id": "JixM5IplKjCgdpw3",
          "name": "GitHub account"
        }
      }
    },
    {
      "id": "04-parse-products",
      "name": "Parse Products",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const content = Buffer.from($input.item.json.content, 'base64').toString('utf-8');\nconst lines = content.split('\\n');\nconst items = [];\nconst seenAsins = new Set();\n\nfor (let i = 0; i < lines.length; i++) {\n  const asinMatch = lines[i].match(/^\\s+asin:\\s*\"([A-Z0-9]{10})\"/);\n  if (!asinMatch) continue;\n  const asin = asinMatch[1];\n  if (seenAsins.has(asin)) continue;\n  seenAsins.add(asin);\n\n  let id = '', name = '', price = '';\n  const start = Math.max(0, i - 15);\n  const end = Math.min(lines.length - 1, i + 10);\n  for (let j = start; j <= end; j++) {\n    if (!id) { const m = lines[j].match(/^\\s+id:\\s*\"([^\"]+)\"/); if (m) id = m[1]; }\n    if (!name) { const m = lines[j].match(/^\\s+name:\\s*\"([^\"]+)\"/); if (m) name = m[1]; }\n    if (!price) { const m = lines[j].match(/^\\s+price:\\s*\"([^\"]+)\"/); if (m) price = m[1]; }\n  }\n  items.push({ json: { asin, id, name, currentPrice: price } });\n}\n\nreturn items;"
      }
    },
    {
      "id": "05-check-cdn",
      "name": "Check ASIN Image CDN",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        0
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://m.media-amazon.com/images/P/' + $json.asin + '.01._SX300_QL70_.jpg' }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      }
    },
    {
      "id": "06-determine-live",
      "name": "Determine Live Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        0
      ],
      "parameters": {
        "jsCode": "const original = $('Parse Products').item.json;\nconst asin = original.asin;\nconst id = original.id;\nconst name = original.name;\nconst currentPrice = original.currentPrice;\n\nlet isLive = false;\ntry {\n  const binaryData = $input.item.binary?.data;\n  if (binaryData) {\n    isLive = binaryData.mimeType === 'image/jpeg' ||\n             binaryData.mimeType === 'image/jpg' ||\n             (binaryData.fileSize !== undefined && binaryData.fileSize > 200);\n  }\n} catch(e) { isLive = false; }\n\nreturn [{ json: {\n  asin,\n  id,\n  name,\n  currentPrice,\n  isLive,\n  imageUrl: 'https://m.media-amazon.com/images/P/' + asin + '.01._SX300_QL70_.jpg',\n  checkedAt: new Date().toISOString()\n}}];"
      }
    },
    {
      "id": "07-aggregate",
      "name": "Aggregate Health Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const sha = $('Get Health JSON SHA').first().json.sha;\nconst healthMap = {};\n\nfor (const item of $input.all()) {\n  const { asin, isLive, imageUrl, checkedAt } = item.json;\n  if (!asin) continue;\n  healthMap[asin] = { isLive, imageUrl: imageUrl || ('https://m.media-amazon.com/images/P/' + asin + '.01._SX300_QL70_.jpg'), checkedAt };\n}\n\nconst liveCount = Object.values(healthMap).filter(h => h.isLive).length;\nconst deadCount = Object.values(healthMap).filter(h => !h.isLive).length;\nconst total = Object.keys(healthMap).length;\n\nconst content = JSON.stringify(healthMap, null, 2);\nconst base64Content = Buffer.from(content).toString('base64');\n\nreturn [{ json: { sha, base64Content, liveCount, deadCount, total } }];"
      }
    },
    {
      "id": "08-commit-health",
      "name": "Commit Health JSON",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
