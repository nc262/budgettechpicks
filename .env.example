# Copy this file to .env.local and fill in your values

# Your Amazon Associates tracking ID (e.g. yoursite-20)
NEXT_PUBLIC_AMAZON_TAG=yoursite-20

# Your Google AdSense Publisher ID (e.g. pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_ID=pub-XXXXXXXXXXXXXXXX

# Optional: Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
