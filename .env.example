# Copy this file to .env.local and fill in your values

# Your Amazon Associates tracking ID (e.g. yoursite-20)
NEXT_PUBLIC_AMAZON_TAG=yoursite-20

# Your Google AdSense Publisher ID (e.g. pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_ID=pub-XXXXXXXXXXXXXXXX

# Optional: Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: newsletter signup endpoint (any Formspree-style JSON POST endpoint).
# Free options: formspree.io (50 subs/mo free) or buttondown.com.
# The signup form stays hidden until this is set — set it in Cloudflare Pages env too.
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=

# Public contact email shown on /contact (set up forwarding for it, or use your own).
NEXT_PUBLIC_CONTACT_EMAIL=hello@totaltechpicks.com

# Set to 1 to show auto-generated "Community Picks" / "Community Intel" sections.
# Left unset during AdSense review (auto-generated content can trigger "low value").
NEXT_PUBLIC_SHOW_AUTO_PICKS=
